# ============================================================
# AI Issue Solver — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# LLM API Keys
# ------------------------------------------------------------

# Anthropic Claude API key (for Backend and Frontend agents)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key (for Reader, Reviewer, and Issue Creator agents)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ------------------------------------------------------------
# GitHub Configuration
# ------------------------------------------------------------

# GitHub Personal Access Token with these scopes:
#   repo (full repo access)
#   issues (read/write)
#   pull_requests (read/write)
# Get yours at: https://github.com/settings/tokens
GH_PAT=ghp_...

# Target GitHub repository in 'owner/repo' format
# Used by main.py when running locally (GitHub Actions sets this automatically)
GITHUB_REPO=my-org/my-repo

# ------------------------------------------------------------
# Pipeline Inputs (set by GitHub Actions automatically)
# When running locally, fill these in manually for testing.
# ------------------------------------------------------------

ISSUE_NUMBER=1
ISSUE_TITLE=Example issue title
ISSUE_BODY=Example issue body with detailed description
ISSUE_URL=https://github.com/my-org/my-repo/issues/1

# ------------------------------------------------------------
# API Server (Agent 0 FastAPI)
# ------------------------------------------------------------

# Optional: API key to protect the /issues endpoint
# Leave blank to disable authentication
API_KEY=

# Comma-separated list of allowed CORS origins
# Use * for development, restrict in production
CORS_ORIGINS=*

# Server host and port
API_HOST=0.0.0.0
API_PORT=8000
